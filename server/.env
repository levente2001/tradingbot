PORT=8080

# --- MODE ---
# demo: paper trading (NO real orders), real market prices via public endpoints
# live: real orders (testnet or mainnet depending on BINANCE_TRADE_BASE_URL)
TRADING_MODE=demo
DEMO_START_USDT=100
DEMO_FEE_BPS=10

# --- BINANCE ---
# Public market data (prices/tickers) - use mainnet for "real realtime" prices:
BINANCE_PUBLIC_BASE_URL=https://api.binance.com

# Signed trading requests (orders) - testnet recommended while developing:
BINANCE_TRADE_BASE_URL=https://testnet.binance.vision

# Backward compatible (optional):
BINANCE_BASE_URL=https://testnet.binance.vision

# Only needed in live mode:
BINANCE_API_KEY=dqRo21NxUjx9rVnNwzb59YEckurAmCUiEr62NE9ReBwGDkw7qMmdeCPSo5oHZCt8
BINANCE_API_SECRET=hpjp2mPFmJezbXuCUNqSVOa8o4vHjiBM1RFmjszMrXq1bsCyaPevok98mjAzP64A

# quote asset
QUOTE_ASSET=USDT

# --- BOT ---
BOT_AUTOSTART=1
# minimum enforced by backend: 10 sec
BOT_INTERVAL_SEC=10

# Minimum order thresholds
MIN_ORDER_USDT=10
MIN_ORDER_USDT_DEMO=1
