{
  "functions": [
    {
      "source": "functions",
      "runtime": "nodejs22",
      "codebase": "default",
      "ignore": [
        ".git",
        ".github",
        "server",
        "worker",
        "hosting",
        "frontend",
        ".vscode"
      ]
    }
  ],
  "hosting": {
    "public": "hosting",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/activateDemoTrader",
        "function": {
          "functionId": "activateDemoTrader",
          "region": "europe-west1"
        }
      },
      {
        "source": "/startTrader",
        "function": {
          "functionId": "startTrader",
          "region": "europe-west1"
        }
      },
      {
        "source": "/stopTrader",
        "function": {
          "functionId": "stopTrader",
          "region": "europe-west1"
        }
      },
      {
        "source": "/tradingStatus",
        "function": {
          "functionId": "tradingStatus",
          "region": "europe-west1"
        }
      },
      {
        "source": "/updateTraderConfig",
        "function": {
          "functionId": "updateTraderConfig",
          "region": "europe-west1"
        }
      },
      {
        "source": "/runTradingLoop",
        "function": {
          "functionId": "runTradingLoop",
          "region": "europe-west1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
